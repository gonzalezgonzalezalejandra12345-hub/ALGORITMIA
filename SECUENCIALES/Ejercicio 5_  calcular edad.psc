
	Proceso calcularedad
		// Desarrolle  un Algoritmo   para  calcular la edad con base al aÒo
		// aqui defino las variables
		Definir aniodenacimiento,edad Como Entero;;
		// aqui pido los datos por teclado
		Escribir ' ingrese  su anio de nacimiento';
		Leer aniodenacimiento;
		// aqui aplico la formula
		edad <- 2026 -aniodenacimiento;
		// aqui muestro el resultado
		Escribir 'usted tiene',  edad,  "aÒos";
		
FinProceso

