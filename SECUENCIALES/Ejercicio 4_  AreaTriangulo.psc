Proceso AreaTriangulo
	// Desarrolle  un Algoritmo   para descubrir el area de un trinagulo
	// aqui defino las variables
	Definir base, altura, area Como Real;
	// aqui pido los datos por teclado
	Escribir ' ingrese la base  del triangulo';
	Leer base;
	Escribir ' ingrese la altura del triangulo';
	Leer altura;
	// aqui aplico la formula
	area <- base*altura/2;
	// aqui muestro el resultado
	Escribir 'El area del triangulo ', area;
FinProceso
