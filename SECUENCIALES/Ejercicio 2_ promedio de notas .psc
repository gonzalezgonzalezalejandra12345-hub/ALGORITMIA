Algoritmo promediodenotas
	//Desarrolle  un Algoritmo  que permita  hallar el promedio de notas
	//aqui defino las variables
	definir nota1, nota2, nota3, promedio Como Real;
	// aqui pido los datos por teclado
	Escribir "nota1";
	Leer nota1;
	Escribir "nota2";
	Leer nota2;
	Escribir "nota3";
	Leer nota3;
	// aqui hago  el calculo matematico
	promedio<- (nota1 + nota2 + nota3) / 3;
	// aqui muestro el resultado
	Escribir" El  promedio final ", promedio;
FinProceso
