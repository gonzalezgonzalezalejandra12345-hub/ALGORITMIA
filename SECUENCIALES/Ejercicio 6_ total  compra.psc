Proceso totalcompra
	// Desarrolle  un Algoritmo   para  calcular  el total de una compra
	// aqui defino las variables
	Definir cantidad, precio, iva, total Como Real;
	// aqui pido los datos por teclado
	Escribir 'ingrese la cantidad de productos ';
	Leer cantidad;
	Escribir 'ingrese el precio del producto';
	Leer precio;
	// aqui aplico la formula
	total <- cantidad*precio;
	// aqui muestro el resultado
	Escribir ' total a pagar', total;
FinProceso
