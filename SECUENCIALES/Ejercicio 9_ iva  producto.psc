Proceso ivaproducto 
	// Desarrolle  un Algoritmo   para  calcular  el IVA en un producto
	// aqui defino las variables
	Definir precio, iva, total Como Real;
	// aqui pido los datos por teclado
	Escribir 'ingrese el precio del producto";
	Leer precio;
	// aqui aplico la formula 
	iva<- precio *19/100 ;
	total<- precio + iva;
	// aqui muestro el resultado
	Escribir 'iva de producto ",iva;
		
FinProceso
