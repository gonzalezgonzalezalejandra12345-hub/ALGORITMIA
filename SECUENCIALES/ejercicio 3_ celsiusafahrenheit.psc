Algoritmo celsiusafahrenheit
		//Desarrolle  un Algoritmo  que permita pasar de celsius a fahrenheit
		//aqui defino las variables
		Definir celsius, fahrenheit Como Real;
		// aqui pido los datos por teclado
		Escribir "ingrese los grados celsius";
		Leer celsius;
		// aqui aplico la formula
		fahrenheit<-  (celsius * 1.8) + 32;	
		// aqui muestro el resultado
		Escribir" Los grados fahrenheit", fahrenheit ;
FinProceso
